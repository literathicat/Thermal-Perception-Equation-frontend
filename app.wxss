/**app.wxss**/
/* 保留原来的容器样式 */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
} 

/* 全局底部悬浮导航栏样式 */
.global-bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 9999;
}

.global-bottom-nav-image {
  width: 100%;
  height: auto;
  display: block;
}

/* 为所有页面添加底部内边距，防止内容被底部导航栏遮挡 */
page {
  padding-bottom: 120rpx !important;
  box-sizing: border-box !important;
}