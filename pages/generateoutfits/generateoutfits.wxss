.page {
  padding: 24rpx;
  color: #1677ff;
}

.phone {
  position: relative;
  width: 92vw;
  max-width: 860rpx;
  margin: 0 auto;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(22, 119, 255, 0.18);
}

.screen {
  width: 100%;
  display: block;
}

.hotspots {
  position: absolute;
  inset: 0;
}

.hotspot {
  position: absolute;
  background: transparent;
  border-radius: 999rpx;
}

.toolbar {
  width: 92vw;
  max-width: 860rpx;
  margin: 24rpx auto 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.home-btn {
  margin: 0;
  padding: 0 24rpx;
  min-width: 196rpx;
  height: 66rpx;
  line-height: 66rpx;
  border-radius: 999rpx;
  border: 2rpx solid #1677ff;
  color: #1677ff;
  background: #ffffff;
  font-size: 28rpx;
}

.home-btn::after {
  border: none;
}

.page-text {
  font-size: 28rpx;
  color: #3b82f6;
}
