<!--pages/myclothes/myclothes.wxml-->
<image src="../../image/返回.png" mode="aspectFit" style="position: absolute; left: 30rpx; top: 20rpx; width: 70rpx; height: 70rpx;"></image>

<image src="../../image/检索.png" mode="aspectFit" style="position: absolute; left: 50%; transform: translateX(-50%); top: -50rpx; width: 90%;"></image>

<image src="../../image/切片1.png" mode="aspectFit" style="position: absolute; left: 50%; transform: translateX(-50%); top: 100rpx; width: 90%;"></image>

<view style="background-color: #ADD8E6;position: absolute; left: 50%; transform: translateX(-50%); top: 440rpx; width: 90%; border-radius:100rpx; height: 100rpx; padding-top: 20rpx;">
  <image src="../../image/品质.png" mode="aspectFit" style="width: 200rpx; height: 200rpx; display: inline-block; position:absolute; top:-40rpx;left:5%;"></image>
  <image src="../../image/季节.png" mode="aspectFit" style="width: 200rpx; height: 200rpx; display: inline-block; margin-left: 20rpx; position:absolute; top:-40rpx;left:33%;"></image>
  <image src="../../image/场景.png" mode="aspectFit" style="width: 200rpx; height:200rpx; display: inline-block; margin-left: 20rpx; position:absolute; top:-40rpx;left:64%;"></image>
</view>
<image src="../../image/蓝色边框.png" mode="aspectFit" style="position: absolute; left: 50%; transform: translateX(-50%); top: 410rpx; width: 90%;" bindtap="toggleCategoryOptions"></image>

<!-- 品类选项弹窗 -->
<view wx:if="{{showCategoryOptions}}" class="category-mask" bindtap="closeCategoryOptions"></view>
<view wx:if="{{showCategoryOptions}}" class="category-options-container">
  <view class="category-options-bg">
    <image src="../../image/选项框-品类.png" mode="aspectFit" class="category-bg-image"></image>
  </view>
  <view class="category-options-content">
    <view class="category-title">选择品类</view>
    <scroll-view scroll-y class="category-list">
      <block wx:for="{{categoryOptions}}" wx:key="id">
        <view class="category-item" bindtap="selectCategory" data-index="{{index}}">
          {{item.name}}
        </view>
      </block>
    </scroll-view>
  </view>
</view>

<image src="../../image/拓展-标签.png" mode="aspectFit" style="position: absolute; right: 10%; top: 550rpx; width: 90rpx; height: 180rpx;"></image>



<view style="display: flex; justify-content: space-between; width: 90%; margin: 0 auto; margin-top: 690rpx;">
  <image src="../../image/衣物1.png" mode="aspectFit" style="width: 45%;"></image>
  <image src="../../image/衣物2.png" mode="aspectFit" style="width: 45%;"></image>
</view>

<view style="display: flex; justify-content: space-between; width: 90%; margin: 0 auto; margin-top: -10rpx;">
  <image src="../../image/衣物3.png" mode="aspectFit" style="width: 45%;"></image>
  <image src="../../image/衣物4.png" mode="aspectFit" style="width: 45%;"></image>
</view>