/* pages/knowledgebase/knowledgebase.wxss */
page {
  height: 100%;
  width: 100%;
  margin: 0;
  padding: 0;
}

.container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.background-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  transform: scale(1.29);
}

.page-header {
  text-align: center;
  padding: 40rpx 20rpx;
  margin-bottom: 30rpx;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.knowledge-cards {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.knowledge-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.knowledge-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.card-category {
  font-size: 24rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 20rpx;
}

.card-content {
  margin-bottom: 20rpx;
}

.card-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.card-date {
  color: #999;
}

.card-readtime {
  color: #52c41a;
}

.load-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 28rpx;
  color: #999;
}

.empty-tips {
  text-align: center;
  padding: 100rpx 20rpx;
  font-size: 32rpx;
  color: #999;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .card-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 10rpx;
  }
  
  .card-category {
    margin-left: 0;
    align-self: flex-start;
  }
  
  .card-footer {
    flex-direction: column;
    align-items: flex-start;
    gap: 10rpx;
  }
}