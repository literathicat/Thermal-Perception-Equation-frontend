/* components/navigation-bar/navigation-bar.wxss */
.nav-container {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 9999;
  pointer-events: none;
}

.nav-background {
  width: 100%;
  height: auto;
  pointer-events: none;
}

.nav-buttons {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 40rpx;
  box-sizing: border-box;
  pointer-events: auto;
}

.nav-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
  flex: 1;
}

.nav-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 8rpx;
}

.nav-text {
  font-size: 20rpx;
  color: #666;
  text-align: center;
}

.nav-button.active .nav-text {
  color: #1890ff;
  font-weight: bold;
}